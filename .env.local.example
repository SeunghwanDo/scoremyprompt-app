# ============================================
# ScoreMyPrompt — Environment Variables
# Copy to .env.local and fill in your values
# ============================================

# ─── Required ───
# Claude API Key (https://console.anthropic.com)
# Without this, app runs in MOCK MODE
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# ─── Supabase (Free tier: 500MB, 2 projects) ───
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# ─── Analytics (PostHog Free: 1M events/month) ───
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx

# ─── Stripe (Phase F에서 설정) ───
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ─── AdSense (Optional) ───
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxx
NEXT_PUBLIC_ADSENSE_SLOT_LEADERBOARD=xxxxx
NEXT_PUBLIC_ADSENSE_SLOT_RECTANGLE=xxxxx

# ─── Optional ───
NEXT_PUBLIC_BASE_URL=https://scoremyprompt.com
